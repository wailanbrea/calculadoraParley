<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Entradas comunes -->
            <EditText
                android:id="@+id/etTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Total JC (ej: 8.0)"
                android:inputType="numberDecimal"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etLineaSiNoPa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Línea (SI/NO y PA, ej: -110)"
                android:inputType="numberSigned"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etMlVisit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="ML Visitante (ej: -120)"
                android:inputType="numberSigned"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etMlCasa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="ML Casa (ej: +110)"
                android:inputType="numberSigned"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etTipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tipo (O/P/U)"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgSide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbCasa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Casa"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbVisitante"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visitante"
                    android:layout_marginStart="16dp" />
            </RadioGroup>

            <Button
                android:id="@+id/btnCalcular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calcular"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvResultadosLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resultados"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvSiNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SI/NO: -"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvPa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PA: -"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvSolo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOLO: -"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="16dp" />

            <!-- TERCIO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TERCIO"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/etTercioH"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="H (ej: 4.0)"
                    android:inputType="numberDecimal" />

                <EditText
                    android:id="@+id/etTercioTipo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="Tipo (O/U/PK)"
                    android:inputType="textCapCharacters"
                    android:layout_marginStart="8dp" />

                <EditText
                    android:id="@+id/etTercioLinea"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="Línea H (ej: -110)"
                    android:inputType="numberSigned"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnBuscarTercio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calcular Tercio"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvTercioResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TERCIO: -"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvTercioError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/holo_red_dark"
                android:layout_marginBottom="16dp" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
